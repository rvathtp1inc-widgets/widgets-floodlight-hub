PORT=8787
HOST=0.0.0.0
DB_PATH=./data/widgets-hub.db
APP_ENCRYPTION_KEY=replace-this-with-a-long-random-secret
TIMER_POLL_SECONDS=5
REQUEST_TIMEOUT_MS=5000
PROTECT_API_ENABLED=false
PROTECT_API_BASE_URL=https://protect.local
PROTECT_API_KEY=
ACCESS_ENABLED=false
# UniFi Access developer API host runs on the console IP over port 12445.
ACCESS_API_BASE_URL=https://10.0.30.1:12445
# ACCESS_API_KEY remains the env var name, but the value must be the UniFi Access Bearer token.
ACCESS_API_KEY=
ACCESS_POLL_INTERVAL_MS=1000
ACCESS_BACKGROUND_POLLING_ENABLED=false
